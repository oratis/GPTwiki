# NextAuth
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# GitHub OAuth
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Resend (for email magic-link sign-in). Create at https://resend.com
# and verify the sending domain before going to production.
AUTH_RESEND_KEY=re_your_resend_api_key
AUTH_EMAIL_FROM=no-reply@gptwiki.net

# Firebase Admin
FIREBASE_PROJECT_ID=gptwiki
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="your-private-key"

# AI API Keys (users select which model to use)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Seedream (Volcengine Ark) for image generation — used by scripts/seed-rich.ts
ARK_API_KEY=your-ark-api-key

# GCS bucket for wiki images (public read) — used by scripts/seed-rich.ts
GCS_WIKI_IMAGES_BUCKET=gptwiki-images
